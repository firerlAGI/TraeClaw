# Sample environment values.
# This file is not auto-loaded by the current scripts.
# Export or set these variables in your shell before starting TraeAPI.

# Trae launch
TRAE_BIN=C:\Path\To\Trae.exe
TRAE_ARGS=
TRAE_REMOTE_DEBUGGING_PORT=9222

# CDP target selection
TRAE_CDP_TARGET_TITLE_CONTAINS=Trae
TRAE_CDP_TARGET_URL_CONTAINS=

# DOM selectors
TRAE_COMPOSER_SELECTORS=textarea,[contenteditable='true']
TRAE_SEND_BUTTON_SELECTORS=button[data-testid='send'],button[type='submit']
TRAE_RESPONSE_SELECTORS=[data-message-author-role='assistant'],.assistant
TRAE_ACTIVITY_SELECTORS=.chat-content-container,.chat-list-wrapper
TRAE_NEW_CHAT_SELECTORS=
TRAE_SEND_TRIGGER=button

# Response collection
TRAE_RESPONSE_POLL_INTERVAL_MS=350
TRAE_RESPONSE_IDLE_MS=1200
TRAE_RESPONSE_TIMEOUT_MS=30000
TRAE_POST_ACTION_DELAY_MS=350
TRAE_SESSION_PREPARE_TIMEOUT_MS=5000
TRAE_SESSION_PREPARE_STABLE_POLLS=2

# Gateway
HOST=127.0.0.1
PORT=8787
TRAE_GATEWAY_TOKEN=
TRAE_ALLOWED_ORIGINS=
TRAE_RATE_LIMIT_WINDOW_MS=60000
TRAE_RATE_LIMIT_MAX_REQUESTS=60
TRAE_ENABLE_DEBUG_ENDPOINTS=0
TRAE_SAFE_ATTACH_ONLY=0
TRAE_ENABLE_MOCK_BRIDGE=0
